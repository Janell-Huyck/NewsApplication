<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApplication.Pages.NewsDetailPage"
             Title="News Details">
    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="15">
            <Image x:Name="DetailImage"
                   HeightRequest="220"
                   Aspect="AspectFill"
                   HorizontalOptions="FillAndExpand"
                   BackgroundColor="{StaticResource Gray200}" />
            <VerticalStackLayout Padding="15" Spacing="12">
                <Label x:Name="DetailTitle"
                       FontSize="Title"
                       FontAttributes="Bold"
                       LineBreakMode="WordWrap" />
                <Label x:Name="DetailText"
                       FontSize="Body"
                       LineBreakMode="WordWrap"
                       LineHeight="1.5" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
